  <properties>
    <google-guava.version>27.1-jre</google-guava.version>
    <spring-cloud.version>2025.0.0</spring-cloud.version>
    <mapstruct.version>1.6.3</mapstruct.version>
    <maven-flatten.version>1.1.0</maven-flatten.version>
    <fastjson.version>1.2.71</fastjson.version>
    <spring-cloud-starter-openfeign.version>4.3.0</spring-cloud-starter-openfeign.version>
    <mybatis.version>3.5.19</mybatis.version>
    <maven-compiler-plugin.version>3.5.1</maven-compiler-plugin.version>
    <aliyun-java-sdk-dysmsapi.version>2.1.0</aliyun-java-sdk-dysmsapi.version>
    <redisson.version>3.42.0</redisson.version>
    <transmittable-thread-local.version>2.14.5</transmittable-thread-local.version>
    <spring-cloud-alibaba.version>2023.0.3.3</spring-cloud-alibaba.version>
    <maven.build.timestamp.format>yyyyMMddHHmmss</maven.build.timestamp.format>
    <hutool-all.version>5.6.3</hutool-all.version>
